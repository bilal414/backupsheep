# ──────────────────────────────────────────────────────────────────────────────
# BackupSheep configuration. Copy this file to .env (`cp .env_sample .env`) and edit.
# The defaults below are wired for the bundled docker-compose stack: `cp .env_sample
# .env`, set a real DJANGO_SECRET_KEY + DB_PASSWORD, then `docker compose up --build`.
# Keys are read at boot; leave the optional ones blank rather than deleting the line.
# ──────────────────────────────────────────────────────────────────────────────

DJANGO_SERVER='prod'
# Keep false in production. Setting it to anything else (true/1/yes/on) enables Django
# debug mode, which leaks tracebacks/settings on errors — never do that on a public host.
DJANGO_DEBUG=false
# Public host(s) this install answers on. Use a real hostname in production (a comma-
# separated list is allowed, e.g. "backup.example.com,www.example.com"). WARNING: setting
# this to '*' disables Django's Host-header validation (host-header injection / cache
# poisoning / password-reset poisoning). Only use '*' behind a proxy that sets Host.
DJANGO_ALLOWED_HOSTS='localhost,127.0.0.1'
# CHANGE THIS to a long random string and keep it STABLE. It signs sessions/tokens and
# derives the key that encrypts stored email credentials — rotating it logs everyone out
# and makes saved email creds undecryptable. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY='change-this-key'
DJANGO_SETTINGS_MODULE='backupsheep.settings'
# Set to true ONLY when this install is served over HTTPS (e.g. behind a TLS-terminating
# reverse proxy). Enables Secure cookies, HSTS, and HTTP->HTTPS redirect.
DJANGO_HTTPS=false

# First-run onboarding gate. The first account created through /onboarding becomes the
# instance admin; the install token proves the person running the wizard has access to
# this server. Leave blank to use the auto-generated token written to
# _storage/install_token on first load (read: docker compose exec web cat
# /code/_storage/install_token), or set a fixed value here for automated installs.
ONBOARDING_INSTALL_TOKEN=''

# Public URL this install is reached at (used for links, OAuth redirects, CSRF origins).
APP_DOMAIN='localhost:8000'
APP_PROTOCOL='http://'
APP_NAME='BackupSheep'

# PostgreSQL. The docker `db` service reads DB_NAME/DB_USER/DB_PASSWORD as its
# POSTGRES_DB/USER/PASSWORD, so set a real password here. PostgreSQL 18 recommended
# (14+ supported by Django 6). For the docker stack keep DB_HOST=db and DB_PORT=5432.
DB_NAME='backupsheep'
DB_USER='backupsheep'
DB_PASSWORD='change-this-password'
DB_HOST='db'
DB_PORT='5432'

# Celery broker for background + scheduled (cron/rate/one-time) backups. For the docker
# stack this points at the bundled `rabbitmq` service; change it for an external broker.
CELERY_BROKER_URL='amqp://guest:guest@rabbitmq:5672//'

# Days to keep backup run logs on local disk before delete_old_logs prunes them.
LOG_RETENTION_DAYS=30

#Optional
SENTRY_DSN=''

# Storage to be used for application logs etc. Tested with AWS S3 and Cloudflare R2
S3_ACCESS_KEY_ID=''
S3_SECRET_ACCESS_KEY=''
S3_STORAGE_BUCKET_NAME=''
S3_ENDPOINT_URL=''
S3_SIGNATURE_VERSION='s3v4'

# POSTMARK - Email Service
POSTMARK_API_KEY=''
POSTMARK_DOMAIN=''
POSTMARK_EMAIL=''
POSTMARK_API_URL='https://api.postmarkapp.com'

# AWS SES - Email Service
SES_REGION_NAME='' # Example us-east-1
SES_REGION_ENDPOINT='' #Example: email.us-east-1.amazonaws.com
SES_ACCESS_KEY_ID=''
SES_SECRET_ACCESS_KEY=''

# Mailgun - Email Service
MAILGUN_DOMAIN=''
MAILGUN_EMAIL=''
MAILGUN_API_KEY=''
MAILGUN_API_URL='https://api.mailgun.net/v3'

# Default transactional-email provider. The first-run wizard can set this per-install;
# this is the fallback. Options: postmark, mailgun, ses. (Email can be left unconfigured,
# but then password-reset emails won't send — recover a lost password with
# `manage.py changepassword <email>`.)
EMAIL_PROVIDER='postmark'

# Slack / Telegram notification channels (optional — email notifications work
# without these). Slack: create an app at https://api.slack.com/apps and fill in
# the OAuth url + client credentials. Telegram: TELEGRAM_BOT_KEY is the bot token
# from BotFather. Leave blank to keep the channel disabled.
SLACK_TOKEN_URL=''
SLACK_CLIENT_ID=''
SLACK_CLIENT_SECRET=''
TELEGRAM_BOT_KEY=''

# Dropbox Storage - Create Dropbox App and add keys here.
#Learn more: https://www.dropbox.com/developers/reference/getting-started#app%20console
DROPBOX_APP_KEY=''
DROPBOX_APP_SECRET=''

# pCloud Storage OAuth (only needed to connect pCloud as a storage destination).
# Defaults point at pCloud's public OAuth hosts; fill in id/secret to enable it.
PCLOUD_CLIENT_ID=''
PCLOUD_CLIENT_SECRET=''

# Basecamp source OAuth (only needed to back up Basecamp).
# Register an app at https://launchpad.37signals.com/integrations
BASECAMP_CLIENT_ID=''
BASECAMP_CLIENT_SECRET=''

# OneDrive Storage
MS_CLIENT_ID=''
MS_OBJECT_ID=''
MS_TENANT_ID=''
MS_APPLICATION_ID=''
MS_CLIENT_SECRET_VALUE=''
MS_CLIENT_SECRET_ID=''
MS_OAUTH_ENDPOINT='https://login.microsoftonline.com/common/oauth2/v2.0/authorize'
MS_OAUTH_TOKEN_URL='https://login.microsoftonline.com/common/oauth2/v2.0/token'
MS_REDIRECT_URL='/api/v1/callback/microsoft'
MS_SCOPE='offline_access Files.ReadWrite.All User.Read'
MS_RESPONSE_TYPE='code'
MS_GRAPH_ENDPOINT='https://graph.microsoft.com/v1.0'

# Cloud provider API endpoints (server/volume snapshots).
# Defaults are baked into settings.py; only set these to override a provider's host.
# DIGITALOCEAN_API='https://api.digitalocean.com'
# HETZNER_API='https://api.hetzner.cloud'
# UPCLOUD_API='https://api.upcloud.com/1.3'
# VULTR_API='https://api.vultr.com'
# GOOGLE_COMPUTE_API='https://compute.googleapis.com'
# GOOGLE_RESOURCE_API='https://cloudresourcemanager.googleapis.com'

# OVH Public Cloud application credentials (required to back up OVH instances/volumes).
# Create an application at the console for your region and fill in the matching pair.
OVH_CA_APP_KEY=''
OVH_CA_APP_SECRET=''
OVH_EU_APP_KEY=''
OVH_EU_APP_SECRET=''
OVH_US_APP_KEY=''
OVH_US_APP_SECRET=''

# GOOGLE Drive Storage
GOOGLE_CLIENT_ID=''
GOOGLE_CLIENT_SECRET=''
